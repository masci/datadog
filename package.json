{
  "name": "datadog-action",
  "version": "1.0.0",
  "private": false,
  "description": "Datadog action",
  "main": "lib/main.js",
  "scripts": {
    "build": "tsc",
    "format": "prettier --write **/*.ts",
    "format-check": "prettier --check **/*.ts",
    "lint": "eslint src/**/*.ts",
    "pack": "ncc build",
    "test": "jest",
    "all": "npm run build && npm run format && npm run lint && npm run pack && npm test"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/actions/typescript-action.git"
  },
  "keywords": [
    "actions",
    "node",
    "setup"
  ],
  "author": "YourNameOrOrganization",
  "license": "MIT",
  "dependencies": {
    "@actions/core": "^1.10.0",
    "@actions/http-client": "^1.0.8",
    "@types/js-yaml": "^3.12.5",
    "js-yaml": "^4.1.1"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/node": "^24.0.0",
    "@typescript-eslint/parser": "^4.12.0",
    "@vercel/ncc": "^0.36.1",
    "eslint": "^7.17.0",
    "eslint-plugin-github": "^4.1.1",
    "eslint-plugin-jest": "^24.4.2",
    "jest": "^30.3.0",
    "jest-circus": "^30.3.0",
    "prettier": "^2.2.1",
    "ts-jest": "^29.4.6",
    "typescript": "^5.9.3"
  }
}
